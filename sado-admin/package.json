{
  "name": "sado-admin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SADO admin dashboard — React 19 + TypeScript + Vite 7",
  "scripts": {
    "dev": "vite",
    "generate:routes": "node scripts/generate-routes.mjs",
    "build": "npm run generate:routes && tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "npm run generate:routes && tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@hookform/resolvers": "3.9.0",
    "@tanstack/react-query": "5.59.0",
    "@tanstack/react-router": "1.95.0",
    "@tanstack/react-table": "8.20.5",
    "clsx": "2.1.1",
    "i18next": "23.16.0",
    "i18next-browser-languagedetector": "8.0.0",
    "lucide-react": "0.453.0",
    "pdf-lib": "1.17.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "7.53.0",
    "react-i18next": "15.1.0",
    "recharts": "2.13.0",
    "sonner": "1.7.4",
    "tailwind-merge": "2.5.4",
    "zod": "3.23.8",
    "zustand": "5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.0",
    "@tanstack/router-generator": "1.95.0",
    "@tanstack/router-plugin": "1.95.0",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.5.0",
    "@testing-library/react": "16.0.1",
    "@testing-library/user-event": "14.5.2",
    "@types/jest-axe": "3.5.9",
    "@types/node": "22.7.5",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@vitejs/plugin-react": "5.0.4",
    "axe-core": "4.10.2",
    "eslint": "9.13.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-react-refresh": "0.4.14",
    "globals": "15.11.0",
    "jest-axe": "9.0.0",
    "jsdom": "25.0.1",
    "prettier": "3.3.3",
    "tailwindcss": "4.2.0",
    "typescript": "5.6.3",
    "typescript-eslint": "8.10.0",
    "vite": "7.0.0",
    "vitest": "2.1.3"
  }
}
