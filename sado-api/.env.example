# Application
APP_NAME=SADO API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Database — SQLite fallback when DATABASE_URL is not provided.
# For production: postgresql+asyncpg://sado:sado@localhost:5432/sado
DATABASE_URL=sqlite+aiosqlite:///./sado.db

# Redis (optional — if unset, an in-memory fallback is used)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MIN=15
REFRESH_TOKEN_EXPIRES_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:8081,http://localhost:19006

# MinIO / S3 (optional — if unset, local filesystem under ./storage is used)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=sado-audio
MINIO_REGION=us-east-1

# Storage fallback
LOCAL_STORAGE_DIR=./storage

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# Rate limiting
RATE_LIMIT_AUTH_PER_MINUTE=10

# Audio constraints
MAX_AUDIO_DURATION_SEC=60
MAX_AUDIO_SIZE_MB=10
