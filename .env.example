# === Database (Postgres) ===
POSTGRES_USER=smartpark
POSTGRES_PASSWORD=smartpark
POSTGRES_DB=smartpark
POSTGRES_HOST=db
POSTGRES_PORT=5432

# === Backend ===
# Used inside docker-compose; for local dev override to localhost.
DATABASE_URL=postgresql+psycopg2://smartpark:smartpark@db:5432/smartpark
JWT_SECRET=change-me-in-production-please-use-long-random-string
JWT_ALG=HS256
JWT_EXP_MINUTES=1440
DEVICE_API_KEY=esp32-device-secret-key
ADMIN_PHONE=+998900000000
ADMIN_PASSWORD=admin123

# === ESP32 firmware (consumed by include/config.h) ===
WIFI_SSID=your-wifi-ssid
WIFI_PASSWORD=your-wifi-password
BACKEND_URL=http://192.168.1.100:8000
DEVICE_ID=esp32_001

# === Android ===
# Read by android/local.properties for BuildConfig.BACKEND_URL
ANDROID_BACKEND_URL=http://10.0.2.2:8000

# === Telegram (optional, orchestrator only) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
